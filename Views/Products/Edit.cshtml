@model PetcoSuppliesMVCAppLskinner.Models.Product

@{
    ViewData["Title"] = "Edit Product";
}

<h1>Edit Product</h1>

<hr />

<!-- Editing a product, exclusive to Staff and Admins -->

<div class="row">
    <div class="col-md-6">

        <form asp-action="Edit"
              enctype="multipart/form-data">

            <div asp-validation-summary="ModelOnly"
                 class="text-danger"></div>

            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Name"
                       class="form-label"></label>

                <input asp-for="Name"
                       class="form-control" />

                <span asp-validation-for="Name"
                      class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description"
                       class="form-label"></label>

                <textarea asp-for="Description"
                          class="form-control"></textarea>

                <span asp-validation-for="Description"
                      class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Price"
                       class="form-label"></label>

                <input asp-for="Price"
                       class="form-control" />

                <span asp-validation-for="Price"
                      class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Stock"
                       class="form-label"></label>

                <input asp-for="Stock"
                       class="form-control" />

                <span asp-validation-for="Stock"
                      class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CategoryId"
                       class="form-label"></label>

                <select asp-for="CategoryId"
                        asp-items="ViewBag.CategoryId"
                        class="form-select"></select>
            </div>

            <div class="mb-3">

                <label class="form-label">
                    Current Image
                </label>

                <br />

                <img src="@Model.ImageUrl"
                     style="width:200px;"
                     class="img-thumbnail" />

            </div>

            <div class="mb-3">
                <label asp-for="ImageFile"
                       class="form-label"></label>

                <input asp-for="ImageFile"
                       class="form-control" />
            </div>

            <button type="submit"
                    class="btn btn-primary">
                Save Changes
            </button>

            <a asp-action="Index"
               class="btn btn-secondary">
                Cancel
            </a>

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}